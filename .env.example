# Email delivery for the contact form (https://resend.com — free tier is fine)
# Without a key, submissions are logged to the server console instead of emailed.
RESEND_API_KEY=

# Where contact form submissions are delivered
CONTACT_EMAIL=contact@beltraindustries.com

# Verified sender. Until beltraindustries.com is verified in Resend,
# the default onboarding@resend.dev sender works out of the box.
CONTACT_FROM=Beltra Industries <onboarding@resend.dev>
